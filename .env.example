# Lay tu: Supabase > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_anon_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# URL frontend dung cho CORS (cap nhat sau khi deploy frontend)
FRONTEND_URL=http://localhost:5173

# Port backend
PORT=3001

# --- Frontend (VITE_ prefix bat buoc) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key
# De trong khi local (dung Vite proxy), dien URL backend khi production
VITE_API_BASE_URL=
