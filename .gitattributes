# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly declare these as text
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.conf  text eol=lf
*.env*  text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
